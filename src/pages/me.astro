const books = [
  ["Too Late to Awaken", "Slavoj Žižek", ["philosophy"]],
  ["Courage to Create", "Rollo May", ["philosophy", "psychology"]],
  ["Foundation and Empire", "Isaac Asimov", ["sci-fi"]],
  ["Heart of a Dog", "Mikhail Bulgakov", ["fiction"]],
