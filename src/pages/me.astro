---

<Layout>
  <div class="grid grid-cols-1 items-start justify-center gap-6 md:grid-cols-2">
    <MeCard>
      <MeCardHeader>
        <MeCardTitle size="lg">My Setup</MeCardTitle>
        <MySetupDetailButton />
      </MeCardHeader>

      <MeCardContent>
        <MySetupSection setupData={setupObject} />
      </MeCardContent>
    </MeCard>

    <MeCard>
      <MeCardHeader>
        <MeCardTitle size="md">Very Opinionated Tier List of Programming Languages</MeCardTitle>
      </MeCardHeader>

      <MeCardContent>
        <div class="grid">
          {
            langTierList.map(([rank, list]) => (
              <div class="even:bg-primary/10 flex items-center gap-4 border-b p-1 first:border-t">
                <h2 class="w-8 border-r pe-1 text-center text-2xl font-bold">{rank}</h2>
                <div class="flex gap-2">
                  {list.map((item) => (
                    <div class="border-r pe-2 last:border-0">{item}</div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </MeCardContent>
    </MeCard>
    <!-- <MeCard>
      <MeCardHeader>
        <MeCardTitle size="md">Genres of Music</MeCardTitle>
      </MeCardHeader>

      <MeCardContent>
        <div class="flex gap-2 flex-wrap px-2">
          {
            musicGenres.map((item) => (
                <p class="text-sm">{item}</p>
            ))
          }
        </div>
      </MeCardContent>
    </MeCard> -->
    <MeCard>
      <MeCardHeader>
        <MeCardTitle size="md">Books I've Read This Year</MeCardTitle>
      </MeCardHeader>
      <MeCardContent>
        <li class="grid">
          {
            books.map(([book, author, tags], i) => (
              <ul class="flex flex-wrap items-center justify-between border-b py-1 last:border-b-0">
                <div class="flex flex-wrap items-baseline justify-start gap-2">
                  <p class="w-2 text-center">{i + 1}</p>
                  <p class="text-primary text-lg font-semibold md:text-xl">{book}</p>
                  <p class="text-base font-light md:text-lg">{author}</p>
                </div>
                <li class="flex gap-2">
                  {tags.map((tag) => (
                    <p class="text-primary-foreground bg-secondary px-2 py-0.5 text-xs md:text-sm">
                      {tag}
                    </p>
                  ))}
                </li>
              </ul>
            ))
          }
        </li>
      </MeCardContent>
    </MeCard>
  </div>
</Layout>
