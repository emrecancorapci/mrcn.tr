---
import { getCollection, render } from "astro:content";

import Tag from "@/components/ui/tag.astro";
import Layout from "@/layouts/layout.astro";
import RecordItem from "./_components/record-item.astro";
import ProjectBlock from "./_components/project-block.astro";

export async function getStaticPaths() {
  const projects = await getCollection("project");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { Content } = await render(Astro.props.project);

const data = Astro.props.project.data;

const [linksClass, linkButtonClass] = (() => {
  switch (data.links?.length) {
    case 1:
      return ["md:grid-cols-1", "rounded-xl"];
    case 2:
      return [
        "md:grid-cols-2",
        "first:border-l-0 first:border-t-0 first:md:rounded-l-xl first:md:rounded-r-none first:rounded-t-xl last:border-e-0 last:border-b-0 last:rounded-r-xl",
      ];
    case 3:
      return [
        "md:grid-cols-3",
        "first:border-l-0 first:border-t-0 first:md:rounded-l-xl first:md:rounded-r-none first:rounded-t-xl last:border-e-0 last:border-b-0 last:rounded-r-xl",
      ];
    case 4:
      return [
        "md:grid-cols-4",
        "first:border-l-0 first:border-t-0 first:md:rounded-l-xl first:md:rounded-r-none first:rounded-t-xl last:border-e-0 last:border-b-0 last:rounded-r-xl",
      ];
    default:
      return ["md:grid-cols-1", "rounded-xl"];
  }
})();
---

<Layout title={data.title}>
  <div class="flex gap-1 px-2 font-bold">
    <a href="/" class="hover:text-secondary/80 underline">home</a>
    >
    <a href="/projects" class="hover:text-secondary/80 underline"> projects </a>
    {` > ${data.title}`}
  </div>
  <div class="grid gap-8 pt-4">
    <div
      class="bg-primary text-background from-primary to-secondary grid gap-4 rounded-xl bg-linear-65 from-20% to-80% px-4 py-30 text-center transition-all duration-1000 ease-out hover:opacity-90"
    >
      <h2 class="text-7xl font-black">{data.title}</h2>
      <p class="font-semibold">{data.description}</p>
    </div>
    {
      data.links && (
        <div class={`bg-card grid grid-cols-1 rounded-xl ${linksClass}`}>
          {data.links.map((link) => (
            <a
              class={`border-y p-2 py-2 text-center text-xl font-bold transition-all duration-300 ease-out md:border-x md:border-y-0 md:py-4 ${linkButtonClass} ${link.primary ? "bg-primary text-background hover:bg-secondary" : "hover:bg-primary/20"}`}
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.title}
            </a>
          ))}
        </div>
      )
    }
    {
      (data.blocks?.filter((b) => b.onTop).length ?? 0) > 0 && (
        <div class="flex md:hidden w-full flex-col gap-4">
          {data.blocks?.map((block) => (
            <ProjectBlock block={block} />
          ))}
        </div>
      )
    }
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-4">
      <div class="bg-card col-span-1 grid rounded-xl px-4 py-2 lg:col-span-3">
        <div class="flex flex-col">
          <h3 class="border-border border-b p-4 text-3xl font-bold">Summary</h3>
          <div class="grid gap-4 p-4 leading-loose">
            <Content />
          </div>
        </div>
      </div>
      {
        (data.blocks?.filter((b) => !b.onTop).length ?? 0) > 0 && (
          <div class="flex w-full flex-col gap-4">
            {data.blocks?.map((block) => (
              <ProjectBlock block={block} />
            ))}
          </div>
        )
      }
    </div>
  </div>
</Layout>

---
