---
interface Props {
  title: string;
  href: string;
  description: string;
  tags: string[];
}

const { title, href, description, tags } = Astro.props;
---

<div
  class="group grid grid-rows-3 rounded-xl py-8 bg-primary hover:bg-secondary transition-all duration-300 ease-out cursor-pointer"
  onclick={`location.href='${href}'`}
>
  <h3 class="text-center font-bold text-2xl text-background transition-all">
    {title}
  </h3>
  <p
    class="row-span-2 flex items-center justify-center px-4 text-center text-background transition-all"
  >
    {description}
  </p>
  <div
    class="flex flex-wrap px-4 gap-2 text-center items-center justify-center"
  >
    {
      tags.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="bg-background hover:bg-secondary hover:text-background py-1 text-sm text-secondary px-2 rounded transition-all duration-300 ease-out"
        >
          {tag}
        </a>
      ))
    }
  </div>
</div>
