---
interface Props {
  key: string;
  value: string;
}

const { key, value } = Astro.props;
---

<div class="grid w-full grid-cols-5 gap-2 border-b pb-1">
  <p class="text-secondary col-span-2 flex w-full justify-between text-sm font-semibold">
    <span>
      {key}
    </span>
    <span> : </span>
  </p>
  <p class="col-span-3 text-sm">{value}</p>
</div>
