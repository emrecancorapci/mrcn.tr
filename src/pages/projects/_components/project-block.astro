---
import Tag from "@/components/ui/tag.astro";
import RecordItem from "./record-item.astro";
import type { ProjectBlock } from "@/schemas/project.schema";

interface Props {
  block: ProjectBlock;
}

const { block} = Astro.props;

---

<div class={`bg-card gap-2 rounded-xl p-5 ${block.onTop ? "grid" : "hidden md:grid"}`}>
  <h3 class="border-b pb-2 text-2xl font-bold">{block.title}</h3>
  <div class="flex flex-wrap gap-2">
    {
      block.type === "tags" &&
        block.content.map((tag: string) => <Tag href={`/tags/${tag}`}>{tag}</Tag>)
    }
    {block.type === "plain" && <p class="text-sm">{block.content}</p>}
    {
      block.type === "list" && (
        <ul class="grid w-full list-disc gap-2 ps-3">
          {block.content.map((item) => (
            <li class="w-full px-1 py-0.5">{item}</li>
          ))}
        </ul>
      )
    }
    {
      block.type === "records" &&
        block.content.map((record) => <RecordItem key={record[0]} value={record[1]} />)
    }
  </div>
</div>
