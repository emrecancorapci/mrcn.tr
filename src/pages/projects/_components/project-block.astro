---
import Tag from "@/components/ui/tag.astro";
import RecordItem from "./record-item.astro";
import type { ProjectBlock } from "@/schemas/project.schema";
import { cn } from "@/lib/utils";
import ProjectSection from "./project-section.astro";
import ProjectSectionTitle from "./project-section-title.astro";

interface Props {
  block: ProjectBlock;
  class?: string;
}

const { block, class: className } = Astro.props;
---

<ProjectSection class={cn(`gap-2 rounded-xl`, className)}>
  <ProjectSectionTitle size="sm" slot="title">{block.title}</ProjectSectionTitle>
  <div class="flex flex-wrap gap-2">
    {
      block.type === "tags" &&
        block.content.map((tag: string) => <Tag href={`/tags/${tag}`}>{tag}</Tag>)
    }
    {block.type === "plain" && <p class="text-sm">{block.content}</p>}
    {
      block.type === "list" && (
        <ul class="grid w-full list-disc gap-2 ps-3">
          {block.content.map((item) => (
            <li class="w-full px-1 py-0.5">{item}</li>
          ))}
        </ul>
      )
    }
    {
      block.type === "records" &&
        block.content.map((record) => <RecordItem key={record[0]} value={record[1]} />)
    }
  </div>
</ProjectSection>
