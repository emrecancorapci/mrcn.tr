---
import Tag from "@/components/ui/tag.astro";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

interface Props {
  experience: CollectionEntry<"experiences">;
}

const { Content } = await render(Astro.props.experience);
const experience = Astro.props.experience.data;
---

<div
  class="bg-secondary-foreground border-secondary/50 grid h-fit gap-4 rounded-xl border px-6 py-6 pb-8 shadow transition-all"
>
  <div class="grid gap-2">
    <div class="flex flex-col justify-center gap-2 md:flex-row md:justify-between">
      <div>
        <h2 class="text-center text-3xl font-bold md:text-start">
          {experience.title} - <span class="text-2xl">{experience.contractType}</span>
        </h2>
        <h3 class="text-secondary text-center text-lg font-extralight md:text-start">
          <span class="text-xl font-normal">{experience.company}</span> - {experience.location}
        </h3>
      </div>
      <div class="flex justify-center pt-0 md:pt-1">
        <p class="text-secondary border-secondary/50 size-fit rounded-lg border px-2 text-center">
          {experience.start} - {experience.end}
        </p>
      </div>
    </div>
  </div>
  <hr class="border-secondary/50" />

  <div
    class:list={[
      "prose pe-8 md:pe-20",
      "prose-li:text-secondary",
      "prose-ul:grid prose-ul:list-disc",
      "prose-strong:text-primary prose-strong:font-bold prose-strong:text-lg",
    ]}
  >
    <Content />
  </div>

  <!-- <hr class="border-secondary/50" /> -->

  <ul class="flex flex-wrap gap-2">
    {
      experience.techs.map((t) => (
        <Tag
          class="bg-secondary-foreground border-secondary/50 text-secondary border text-center",
          Element="li"
          variant="secondary"
        >
          {t}
        </Tag>
      ))
    }
  </ul>
</div>
