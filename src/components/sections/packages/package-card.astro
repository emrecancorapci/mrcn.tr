---
interface Props {
  title: string;
  href: string;
  description: string;
}

const { title, href, description } = Astro.props;
---
<a
  class="group grid grid-rows-3 border border-primary py-8 bg-background hover:bg-primary transition-all"
  href={href} >
    <h3 class="text-center font-bold text-2xl text-primary group-hover:text-background transition-all">
      {title}
    </h3>
    <p class="row-span-2 flex items-center justify-center px-4 text-center text-tertiary group-hover:text-background transition-all">
      {description}
    </p>
</a>
