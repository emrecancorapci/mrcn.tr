---
import { Icon } from "astro-icon/components";

import NavLink from "./nav-link.astro";
import ExternNavLink from "./extern-nav-link.astro";

interface Props {
  hasBorder?: boolean;
  forceCol?: boolean;
  disableHomePageText?: boolean;
  isHomePage?: boolean;
}

const {
  hasBorder = false,
  forceCol = false,
  disableHomePageText = false,
  isHomePage = false,
} = Astro.props as Props;
---

<header
  class=`p-6 flex flex-col gap-4 justify-between items-center ${forceCol ? "" : "md:flex-row "} ${hasBorder ? "border-b border-border" : ""}`
>
  <a
    class=`group relative block overflow-hidden font-black ${forceCol ? "text-center text-4xl" : "text-4xl md:text-3xl"}`
    href="/"
  >
    <span
      class=`block transition-all duration-200 ${disableHomePageText ? "" : "group-hover:-translate-y-full group-hover:opacity-0"}`
    >
      EMRE CAN ÇORAPÇI
    </span>

    <span
      class=`absolute inset-0 block text-center translate-y-full transition-all duration-200 ${disableHomePageText ? "" : "group-hover:translate-y-0 group-hover:opacity-100"}`
    >
      HOME PAGE
    </span>
  </a>
  <nav class="flex justify-center gap-4">
    <NavLink href="/projects">Projects</NavLink>
    <!-- <NavLink href="/techs">Technologies</NavLink> -->
    <NavLink href="/me">Me</NavLink>
    <!-- <NavLink href="/blog">Blog</NavLink> -->
  </nav>
  {
    isHomePage ?
      <div class="bg-border block h-px w-full" />
    : <div class="bg-border block h-px w-full md:hidden" />
  }
  <div class="flex items-center justify-end gap-2">
    <ExternNavLink href="https://linkedin.com/in/emrecancorapci">
      <Icon name="simple-icons:linkedin" class="text-2xl" />
    </ExternNavLink>
    <ExternNavLink href="https://github.com/emrecancorapci">
      <Icon name="simple-icons:github" class="text-2xl" />
    </ExternNavLink>
    <ExternNavLink href="mailto:emrecancorapci@gmail.com">
      <Icon name="material-symbols:mail-rounded" class="-m-0.5 -mt-0.75 text-center text-3xl" />
    </ExternNavLink>
    <ExternNavLink href="/docs/emre_can_corapci_cv.pdf">
      <p class="-mt-1 text-2xl font-black">CV</p>
    </ExternNavLink>
  </div>
</header>
