---
import { FileUserIcon, GithubIcon, LinkedinIcon, MailIcon } from "@lucide/astro";
import ContactBadge from "./contact-badge.astro";
---

<div class="flex justify-center">
  <div class="grid w-fit grid-cols-4 gap-2">
    <ContactBadge href="https://linkedin.com/in/emrecancorapci">
      <LinkedinIcon width={24} height={24} stroke-width={1.25} />
      LinkedIn
    </ContactBadge>
    <ContactBadge href="https://github.com/emrecancorapci">
      <GithubIcon width={24} height={24} stroke-width={1.25} />
      Github
    </ContactBadge>
    <ContactBadge href="mailto:emrecancorapci@gmail.com">
      <MailIcon width={24} height={24} stroke-width={1.25} />
      E-Mail
    </ContactBadge>
    <ContactBadge href="/docs/emre_can_corapci_cv.pdf">
      <FileUserIcon width={24} height={24} stroke-width={1.25} />
      CV
    </ContactBadge>
  </div>
</div>
