---
import { cn } from "@/lib/utils";

interface Props {
  Element?: "a" | "p" | "li";
  href?: string;
  variant?: "primary" | "secondary" | "tertiary";
  class?: string;
}

const { Element = "p", href, variant = "primary", class: className } = Astro.props;

const variantString = (() => {
  switch (variant) {
    case "primary":
      return `bg-primary-foreground rounded text-secondary ${href && `hover:bg-secondary hover:text-primary-foreground`}`;
    case "secondary":
      return `bg-secondary text-primary-foreground rounded-lg font-light ${href && `hover:bg-tertiary hover:text-background`}`;
    case "tertiary":
      return `bg-tertiary text-primary-foreground rounded-lg font-light ${href && `hover:bg-secondary hover:text-background`}`;
    default:
      return "bg-background hover:bg-secondary rounded hover:text-background";
  }
})();

const classString = cn([
  "py-1 text-sm px-2 transition-all duration-300 ease-out",
  variantString,
  className,
]);
---

{
  (
    <Element class={classString} {...{ href }}>
      <slot />
    </Element>
  )
}
