---
import "@/styles/global.css";

import {
  FileUserIcon,
  GithubIcon,
  LinkedinIcon,
  MailIcon,
} from "@lucide/astro";
import PostHog from "@/components/post-hog.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Emre Can Çorapçı</title>
    <PostHog />
  </head>
  <body
    class="flex justify-center min-h-screen min-w-screen bg-background text-foreground"
  >
    <div class="grid flex-col w-full max-w-7xl">
      <div
        class="grid p-6 grid-cols-12 items-center row-start-1 row-end-2 w-full"
      >
        <a href="/" class="col-span-2 font-black">EMRE CAN</a>
        <div class="flex gap-4 justify-center col-start-3 col-end-9">
          <a href="/projects">Projects</a>
          <a href="/techs">Technologies</a>
          <a>Personal</a>
          <a>Blog</a>
        </div>
        <div
          class="grid grid-cols-4 ps-18 gap-4 justify-end items-center col-start-11 col-end-13"
        >
          <div class="text-center size-6">
            <LinkedinIcon width={24} height={24} stroke-width={1.25} />
          </div>
          <div class="text-center size-6">
            <GithubIcon width={24} height={24} stroke-width={1.25} />
          </div>
          <div class="text-center size-6">
            <MailIcon width={24} height={24} stroke-width={1.25} />
          </div>
          <div class="text-center size-6">
            <FileUserIcon width={24} height={24} stroke-width={1.25} />
          </div>
        </div>
      </div>
      <div class="row-start-3 px-8 row-end-11">
        <slot />
      </div>
      <div class="row-start-12 px-2 row-end-13">Footer</div>
    </div>
  </body>
</html>
