---
import "@/styles/global.css";

import {
  FileUserIcon,
  GithubIcon,
  LinkedinIcon,
  MailIcon,
} from "@lucide/astro";
import PostHog from "@/components/post-hog.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? "Emre Can Çorapçı"}</title>
    <meta
      name="description"
      content={description ?? "Emre Can Çorapçı's personal website"}
    />
    <PostHog />
  </head>
  <body
    class="flex justify-center min-h-screen min-w-screen bg-background text-foreground"
  >
    <div class="grid flex-col w-full max-w-7xl">
      <div
        class="grid p-6 grid-cols-12 items-center row-start-1 row-end-2 w-full"
      >
        <a href="/" class="col-span-2 font-black">EMRE CAN</a>
        <div class="flex gap-4 justify-center col-start-3 col-end-9">
          <a href="/projects">Projects</a>
          <a href="/techs">Technologies</a>
          <a>Personal</a>
          <a>Blog</a>
        </div>
        <div
          class="grid grid-cols-4 ps-18 gap-4 justify-end items-center col-start-11 col-end-13"
        >
          <a
            href="https://linkedin.com/in/emrecancorapci"
            class="text-center hover:text-secondary/80 size-6"
            target="_blank"
            rel="noopener noreferrer"
          >
            <LinkedinIcon width={24} height={24} stroke-width={1.25} />
          </a>
          <a
            href="https://github.com/emrecancorapci"
            class="text-center hover:text-secondary/80 size-6"
            target="_blank"
            rel="noopener noreferrer"
          >
            <GithubIcon width={24} height={24} stroke-width={1.25} />
          </a>
          <a
            href="mailto:emrecancorapci@gmail.com"
            class="text-center hover:text-secondary/80 size-6"
            target="_blank"
            rel="noopener noreferrer"
          >
            <MailIcon width={24} height={24} stroke-width={1.25} />
          </a>
          <a
            href="/docs/emre_can_corapci_cv.pdf"
            class="text-center hover:text-secondary/80 size-6"
            target="_blank"
            rel="noopener noreferrer"
          >
            <FileUserIcon width={24} height={24} stroke-width={1.25} />
          </a>
        </div>
      </div>
      <div class="row-start-3 px-8 row-end-11">
        <slot />
      </div>
      <div class="row-start-12 px-2 row-end-13">Footer</div>
    </div>
  </body>
</html>
